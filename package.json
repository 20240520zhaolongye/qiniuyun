{
  "name": "spriteforge",
  "version": "1.0.0",
  "private": true,
  "description": "A zero-dependency 2D game asset generator MVP for text and parameter driven sprite creation.",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-cpp.ps1",
    "start:node": "node server.js",
    "start:api": "backend\\.venv\\Scripts\\python.exe backend/run.py",
    "build": "powershell -ExecutionPolicy Bypass -File scripts/build-cpp.ps1",
    "test": "node --test tests/*.test.js",
    "test:backend": "backend\\.venv\\Scripts\\python.exe -m pytest backend/tests",
    "test:all": "npm test && npm run test:backend"
  },
  "keywords": [
    "2d-game",
    "sprite",
    "asset-generator",
    "canvas",
    "game-dev"
  ],
  "author": "",
  "license": "MIT",
  "type": "module"
}
